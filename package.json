{
  "name": "checkapp",
  "version": "1.0.0",
  "description": "Plagiarism checker for AI-generated articles. Terminal UI powered by Ink + Copyscape.",
  "bin": {
    "checkapp": "./src/index.tsx"
  },
  "scripts": {
    "start": "bun src/index.tsx",
    "setup": "bun src/index.tsx --setup",
    "build": "bash build.sh",
    "dev": "bun --watch src/index.tsx",
    "test": "bun test src/*.test.ts src/skills/*.test.ts src/utils/*.test.ts",
    "test:dashboard": "cd dashboard && bunx vitest run",
    "test:all": "bun run test && bun run test:dashboard"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "exa-js": "^2.11.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "open": "^11.0.0",
    "openai": "^6.34.0",
    "proper-lockfile": "^4.1.2",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^18.3.1",
    "bun-types": "latest"
  }
}
