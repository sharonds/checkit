# CheckApp — environment variables
#
# Copy this file to .env and fill in your keys.
# Keys here take precedence over ~/.checkapp/config.json.
#
# Alternatively, run `checkapp --setup` to save keys interactively.

# ── Copyscape ────────────────────────────────────────────────────────────────
# Get your credentials at: https://www.copyscape.com/apiconfigure.php
COPYSCAPE_USER=
COPYSCAPE_KEY=

# ── Parallel AI (optional) ───────────────────────────────────────────────────
# Enables passage-level evidence — shows exactly which sentences were copied.
# Get your key at: https://platform.parallel.ai
PARALLEL_API_KEY=

# ── OpenAlex — academic citations provider (default, recommended) ────────────
# Free service; the mailto identifies your client for the polite pool
# (100k requests/day). No API key required.
OPENALEX_MAILTO=your-email@example.com
